# A-Roll Rough Cut Tool - Environment Variables
# Copy this file to .env and fill in your values
# 也可以通过 Web UI「服务配置」页面直接填写

# ========== LLM 智能匹配服务 ==========
# 支持火山方舟 / OpenAI / DeepSeek / 任何 OpenAI 兼容 API
ARK_API_KEY=
# 可选：修改 Base URL 和 Model 以切换供应商
# 火山方舟: https://ark.cn-beijing.volces.com/api/coding/v3
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
CLOUD_BASE_URL=
CLOUD_MODEL=

# ========== 火山音视频字幕生成 ==========
VOLCENGINE_CAPTION_APPID=
VOLCENGINE_CAPTION_TOKEN=

# 可选：火山热词 / 替换词表 ID
VOLCENGINE_CAPTION_BOOSTING_TABLE_ID=
VOLCENGINE_CAPTION_CORRECT_TABLE_ID=
